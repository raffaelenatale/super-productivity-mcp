# Port must match the Socket.IO URL hardcoded in the plugin (default: http://127.0.0.1:3996)
PORT=3996
MCP_HOST=127.0.0.1

# Optional Socket.IO tuning (plugin bridge ↔ MCP server)
# SOCKET_IO_PING_TIMEOUT_MS=120000
# SOCKET_IO_PING_INTERVAL_MS=25000
# SOCKET_IO_CONNECT_TIMEOUT_MS=120000

# Optional: directory that contains your docker-compose.yml for the MCP server.
# Used by scripts/restart-mcp-docker.sh (and npm run docker:restart).
# If unset, the script uses this repository root when docker-compose.yml exists here.
# MCP_DOCKER_COMPOSE_DIR=/path/to/docker/apps/super-productivity-mcp
